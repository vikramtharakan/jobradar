"use client";
import { useState, useEffect } from "react";
import { ls, lsSave } from "./storage";

const CATEGORIES = ["ML Fundamentals", "Data Engineering", "System Design", "Coding", "Behavioral"];
const CAT_COLORS = { "ML Fundamentals": "#6366f1", "Data Engineering": "#3b82f6", "System Design": "#8b5cf6", "Coding": "#22c55e", "Behavioral": "#f59e0b" };
const CAT_ICONS = { "ML Fundamentals": "🧠", "Data Engineering": "🔧", "System Design": "🏗️", "Coding": "💻", "Behavioral": "🗣️" };

const SUGGESTED_TOPICS = {
  "ML Fundamentals": ["Transformer architecture deep-dive", "Entity resolution techniques", "Deep metric learning", "Active learning strategies", "LLM fine-tuning approaches", "Embedding models and vector search"],
  "Data Engineering": ["Apache Spark internals and optimization", "Kafka architecture and guarantees", "Elasticsearch indexing and querying", "Graph database design with Neo4j", "ETL pipeline design patterns", "Data lake vs data warehouse tradeoffs"],
  "System Design": ["Design a real-time ML feature store", "Design a scalable NLP pipeline", "Design an entity resolution system at scale", "Design a recommendation system", "Design a data ingestion platform", "ML model serving architecture"],
  "Coding": ["Implement Fellegi-Sunter probabilistic matching", "Write a custom tokenizer", "Optimize a Spark job", "Graph traversal algorithms", "Similarity scoring between embeddings", "Streaming data processing"],
  "Behavioral": ["Navigating ambiguous requirements on classified projects", "Leading without authority on cross-team efforts", "Delivering under tight deadlines", "Handling disagreements with senior engineers", "Onboarding and knowledge transfer"],
};

function CategoryPill({ cat, active, onClick }) {
  const color = CAT_COLORS[cat];
  return (
    <button onClick={onClick}
      style={{ background: active ? color + "33" : "#0f172a", border: `1px solid ${active ? color : "#1e293b"}`, color: active ? color : "#64748b", borderRadius: 8, padding: "6px 14px", fontSize: 12, fontWeight: active ? 700 : 400, cursor: "pointer", display: "flex", alignItems: "center", gap: 6, transition: "all 0.2s" }}>
      {CAT_ICONS[cat]} {cat}
    </button>
  );
}

function TopicCard({ topic, onSelect }) {
  return (
    <button onClick={() => onSelect(topic.topic, topic.category)}
      style={{ background: "#0f172a", border: "1px solid #1e293b", borderRadius: 10, padding: "14px 16px", textAlign: "left", cursor: "pointer", transition: "all 0.2s", width: "100%" }}
      onMouseEnter={e => { e.currentTarget.style.borderColor = CAT_COLORS[topic.category]; e.currentTarget.style.background = "#0f172a"; }}
      onMouseLeave={e => { e.currentTarget.style.borderColor = "#1e293b"; }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 6 }}>
        <span style={{ fontSize: 13, fontWeight: 700, color: "#f1f5f9" }}>{topic.topic}</span>
        <span style={{ fontSize: 10, background: CAT_COLORS[topic.category] + "22", color: CAT_COLORS[topic.category], borderRadius: 4, padding: "2px 7px", fontWeight: 600, flexShrink: 0, marginLeft: 8 }}>{topic.category}</span>
      </div>
      <div style={{ fontSize: 12, color: "#64748b" }}>{topic.tldr}</div>
    </button>
  );
}

function LearningModule({ module, onBack }) {
  const color = CAT_COLORS[module.category] || "#6366f1";
  return (
    <div style={{ animation: "fadeIn 0.4s ease" }}>
      <button onClick={onBack} style={{ background: "transparent", border: "none", color: "#6366f1", cursor: "pointer", fontSize: 13, marginBottom: 20, padding: 0 }}>← Back</button>
      <div style={{ background: "#0f172a", border: `1px solid ${color}33`, borderRadius: 16, padding: "24px 28px", marginBottom: 20 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 16 }}>
          <div>
            <span style={{ fontSize: 10, background: color + "22", color, borderRadius: 4, padding: "2px 8px", fontWeight: 700, letterSpacing: "0.1em" }}>{module.category?.toUpperCase()}</span>
            <h2 style={{ fontSize: 22, fontWeight: 700, fontFamily: "Georgia,serif", color: "#f1f5f9", marginTop: 8 }}>{module.topic}</h2>
          </div>
        </div>
        <div style={{ background: color + "11", border: `1px solid ${color}22`, borderRadius: 8, padding: "12px 16px", marginBottom: 20 }}>
          <div style={{ fontSize: 10, color, fontWeight: 700, letterSpacing: "0.1em", marginBottom: 4 }}>TL;DR</div>
          <div style={{ color: "#cbd5e1", fontSize: 14, lineHeight: 1.6 }}>{module.tldr}</div>
        </div>
        <div style={{ color: "#94a3b8", fontSize: 14, lineHeight: 1.8, marginBottom: 20 }}>{module.explanation}</div>
        <div style={{ background: "#020817", borderRadius: 8, padding: "14px 18px", marginBottom: 16 }}>
          <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 10 }}>WHY IT MATTERS AT SENIOR LEVEL</div>
          <div style={{ color: "#94a3b8", fontSize: 13, lineHeight: 1.6 }}>{module.why_it_matters}</div>
        </div>
        <div style={{ marginBottom: 16 }}>
          <div style={{ fontSize: 10, color: color, fontWeight: 700, letterSpacing: "0.1em", marginBottom: 10 }}>KEY POINTS</div>
          {module.key_points?.map((p, i) => <div key={i} style={{ color: "#cbd5e1", fontSize: 13, marginBottom: 8, paddingLeft: 16, borderLeft: `2px solid ${color}44` }}>▸ {p}</div>)}
        </div>
        {module.common_mistakes?.length > 0 && (
          <div style={{ marginBottom: 16 }}>
            <div style={{ fontSize: 10, color: "#ef4444", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 10 }}>COMMON MISTAKES</div>
            {module.common_mistakes.map((m, i) => <div key={i} style={{ color: "#cbd5e1", fontSize: 13, marginBottom: 6 }}>⚠ {m}</div>)}
          </div>
        )}
        {module.related_topics?.length > 0 && (
          <div>
            <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 8 }}>RELATED TOPICS</div>
            <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
              {module.related_topics.map(t => <span key={t} style={{ fontSize: 11, background: "#1e293b", color: "#94a3b8", borderRadius: 4, padding: "3px 9px" }}>{t}</span>)}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

function PracticeQuestion({ question: q, onBack, onNext }) {
  const [showAnswer, setShowAnswer] = useState(false);
  const [userAnswer, setUserAnswer] = useState("");
  const [evaluation, setEvaluation] = useState(null);
  const [evaluating, setEvaluating] = useState(false);
  const color = CAT_COLORS[q.category] || "#6366f1";

  const evaluate = async () => {
    setEvaluating(true);
    try {
      const res = await fetch("/api/prep", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ type: "evaluate_answer", topic: q.question, userAnswer }) });
      setEvaluation(await res.json());
    } catch { setEvaluation({ score: 0, grade: "Error", strengths: [], improvements: [], missed_points: [], ideal_additions: "", overall_feedback: "Evaluation failed." }); }
    setEvaluating(false);
  };

  const gradeColor = { Strong: "#22c55e", Good: "#86efac", "Needs Work": "#f59e0b", Weak: "#ef4444" }[evaluation?.grade] || "#94a3b8";

  return (
    <div style={{ animation: "fadeIn 0.4s ease" }}>
      <button onClick={onBack} style={{ background: "transparent", border: "none", color: "#6366f1", cursor: "pointer", fontSize: 13, marginBottom: 20, padding: 0 }}>← Back</button>
      <div style={{ background: "#0f172a", border: `1px solid ${color}33`, borderRadius: 16, padding: "24px 28px", marginBottom: 16 }}>
        <div style={{ display: "flex", gap: 8, marginBottom: 16, flexWrap: "wrap" }}>
          <span style={{ fontSize: 10, background: color + "22", color, borderRadius: 4, padding: "2px 8px", fontWeight: 700 }}>{q.category}</span>
          <span style={{ fontSize: 10, background: "#334155", color: "#94a3b8", borderRadius: 4, padding: "2px 8px", fontWeight: 600 }}>{q.difficulty}</span>
        </div>
        <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 8 }}>INTERVIEW QUESTION</div>
        <h2 style={{ fontSize: 18, fontWeight: 700, color: "#f1f5f9", lineHeight: 1.5, marginBottom: 12 }}>{q.question}</h2>
        <div style={{ color: "#64748b", fontSize: 12, fontStyle: "italic", marginBottom: 20 }}>Testing: {q.context}</div>

        {!showAnswer && (
          <div style={{ marginBottom: 16 }}>
            <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 8 }}>YOUR ANSWER</div>
            <textarea value={userAnswer} onChange={e => setUserAnswer(e.target.value)} placeholder="Type your answer here — then get it evaluated by Claude..."
              style={{ width: "100%", background: "#020817", border: "1px solid #1e293b", borderRadius: 8, padding: "12px 14px", color: "#cbd5e1", fontSize: 13, resize: "vertical", minHeight: 120, fontFamily: "inherit" }} />
            <div style={{ display: "flex", gap: 10, marginTop: 10 }}>
              {userAnswer.trim().length > 20 && (
                <button onClick={evaluate} disabled={evaluating}
                  style={{ background: evaluating ? "#1e293b" : "linear-gradient(135deg,#6366f1,#8b5cf6)", color: evaluating ? "#475569" : "white", border: "none", borderRadius: 8, padding: "10px 20px", fontSize: 13, fontWeight: 700, cursor: evaluating ? "not-allowed" : "pointer" }}>
                  {evaluating ? "⟳ Evaluating..." : "⚡ Evaluate My Answer"}
                </button>
              )}
              <button onClick={() => setShowAnswer(true)} style={{ background: "transparent", border: "1px solid #334155", color: "#64748b", borderRadius: 8, padding: "10px 16px", fontSize: 13, cursor: "pointer" }}>Show model answer</button>
            </div>
          </div>
        )}

        {evaluation && (
          <div style={{ background: "#020817", border: `1px solid ${gradeColor}44`, borderRadius: 10, padding: "16px 20px", marginBottom: 16 }}>
            <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 14 }}>
              <div style={{ fontSize: 32, fontWeight: 700, color: gradeColor, fontFamily: "monospace" }}>{evaluation.score}/10</div>
              <span style={{ fontSize: 12, fontWeight: 700, color: gradeColor, background: gradeColor + "22", borderRadius: 6, padding: "4px 10px" }}>{evaluation.grade}</span>
            </div>
            <div style={{ color: "#94a3b8", fontSize: 13, lineHeight: 1.6, marginBottom: 14, fontStyle: "italic" }}>{evaluation.overall_feedback}</div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 14, marginBottom: 12 }}>
              {evaluation.strengths?.length > 0 && (
                <div>
                  <div style={{ fontSize: 10, color: "#22c55e", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 6 }}>STRENGTHS</div>
                  {evaluation.strengths.map((s, i) => <div key={i} style={{ color: "#cbd5e1", fontSize: 12, marginBottom: 4 }}>✓ {s}</div>)}
                </div>
              )}
              {evaluation.improvements?.length > 0 && (
                <div>
                  <div style={{ fontSize: 10, color: "#f59e0b", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 6 }}>IMPROVE</div>
                  {evaluation.improvements.map((s, i) => <div key={i} style={{ color: "#cbd5e1", fontSize: 12, marginBottom: 4 }}>△ {s}</div>)}
                </div>
              )}
            </div>
            {evaluation.missed_points?.filter(Boolean).length > 0 && (
              <div style={{ marginBottom: 12 }}>
                <div style={{ fontSize: 10, color: "#ef4444", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 6 }}>MISSED</div>
                {evaluation.missed_points.filter(Boolean).map((p, i) => <div key={i} style={{ color: "#cbd5e1", fontSize: 12, marginBottom: 4 }}>✗ {p}</div>)}
              </div>
            )}
            {evaluation.ideal_additions && <div style={{ color: "#64748b", fontSize: 12, fontStyle: "italic", borderTop: "1px solid #1e293b", paddingTop: 10 }}>To score 10/10: {evaluation.ideal_additions}</div>}
            <button onClick={() => setShowAnswer(true)} style={{ background: "transparent", border: "1px solid #334155", color: "#64748b", borderRadius: 6, padding: "6px 14px", fontSize: 12, cursor: "pointer", marginTop: 10 }}>See model answer</button>
          </div>
        )}

        {showAnswer && (
          <div style={{ background: "#020817", borderRadius: 10, padding: "16px 20px", borderLeft: `3px solid ${color}` }}>
            <div style={{ fontSize: 10, color: color, fontWeight: 700, letterSpacing: "0.1em", marginBottom: 10 }}>MODEL ANSWER</div>
            <div style={{ color: "#94a3b8", fontSize: 13, lineHeight: 1.8, marginBottom: 14 }}>{q.sample_answer}</div>
            {q.hints?.length > 0 && (
              <div style={{ marginBottom: 10 }}>
                <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 6 }}>HINTS</div>
                {q.hints.map((h, i) => <div key={i} style={{ color: "#64748b", fontSize: 12, marginBottom: 4 }}>• {h}</div>)}
              </div>
            )}
            {q.follow_up_questions?.length > 0 && (
              <div>
                <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 6 }}>LIKELY FOLLOW-UPS</div>
                {q.follow_up_questions.map((f, i) => <div key={i} style={{ color: "#64748b", fontSize: 12, marginBottom: 4 }}>→ {f}</div>)}
              </div>
            )}
          </div>
        )}
      </div>
      <button onClick={onNext} style={{ background: "linear-gradient(135deg,#6366f1,#8b5cf6)", color: "white", border: "none", borderRadius: 8, padding: "10px 24px", fontSize: 13, fontWeight: 700, cursor: "pointer" }}>Next Question →</button>
    </div>
  );
}

export default function InterviewPrep() {
  const [prepTab, setPrepTab] = useState("learn");
  const [selectedCat, setSelectedCat] = useState(null);
  const [loadingTopic, setLoadingTopic] = useState(false);
  const [loadingQ, setLoadingQ] = useState(false);
  const [currentModule, setCurrentModule] = useState(null);
  const [currentQ, setCurrentQ] = useState(null);
  const [savedTopics, setSavedTopics] = useState([]);
  const [history, setHistory] = useState([]);

  useEffect(() => {
    setSavedTopics(ls("prep-topics", []));
    setHistory(ls("prep-history", []));
  }, []);

  const fetchTopic = async (topicName, cat) => {
    setLoadingTopic(true); setCurrentModule(null);
    try {
      const res = await fetch("/api/prep", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ type: "daily_topic", topic: topicName }) });
      const data = await res.json();
      setCurrentModule(data);
      const updated = [data, ...savedTopics.filter(t => t.topic !== data.topic)].slice(0, 20);
      setSavedTopics(updated); lsSave("prep-topics", updated);
      const h = [{ type: "topic", topic: data.topic, category: data.category, date: new Date().toISOString() }, ...history].slice(0, 50);
      setHistory(h); lsSave("prep-history", h);
    } catch { alert("Failed to load topic — check your API key."); }
    setLoadingTopic(false);
  };

  const fetchQuestion = async (cat) => {
    setLoadingQ(true); setCurrentQ(null);
    try {
      const res = await fetch("/api/prep", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ type: "practice_question", topic: cat || selectedCat || "mix", difficulty: "senior" }) });
      const data = await res.json();
      setCurrentQ(data);
      const h = [{ type: "question", topic: data.question?.slice(0, 60) + "...", category: data.category, date: new Date().toISOString() }, ...history].slice(0, 50);
      setHistory(h); lsSave("prep-history", h);
    } catch { alert("Failed to load question."); }
    setLoadingQ(false);
  };

  const todayHistory = history.filter(h => new Date(h.date).toDateString() === new Date().toDateString());

  return (
    <div>
      <div style={{ borderBottom: "1px solid #0f172a", padding: "0 28px", background: "#020817", position: "sticky", top: 54, zIndex: 90 }}>
        <div style={{ maxWidth: 900, margin: "0 auto", display: "flex", gap: 2, height: 44, alignItems: "center" }}>
          {[["learn","📖 Learn"],["practice","🎯 Practice"],["history","📊 History"]].map(([id, label]) => (
            <button key={id} onClick={() => { setPrepTab(id); setCurrentModule(null); setCurrentQ(null); }}
              style={{ background: prepTab === id ? "#1e293b" : "transparent", color: prepTab === id ? "#f1f5f9" : "#475569", border: "none", borderRadius: 6, padding: "5px 14px", fontSize: 13, fontWeight: prepTab === id ? 600 : 400, cursor: "pointer" }}>
              {label}
            </button>
          ))}
        </div>
      </div>

      <div style={{ maxWidth: 900, margin: "0 auto", padding: "28px 24px" }}>

        {/* LEARN */}
        {prepTab === "learn" && !currentModule && (
          <div style={{ animation: "fadeIn 0.4s ease" }}>
            <div style={{ marginBottom: 24 }}>
              <h2 style={{ fontSize: 26, fontWeight: 700, fontFamily: "Georgia,serif", color: "#f1f5f9", letterSpacing: "-0.02em" }}>Daily Learning</h2>
              <p style={{ color: "#475569", fontSize: 13, marginTop: 4 }}>Pick a topic to get a deep-dive explanation tailored to senior ML/DE interviews</p>
              {todayHistory.length > 0 && <p style={{ color: "#22c55e", fontSize: 12, marginTop: 6 }}>✓ {todayHistory.length} session{todayHistory.length !== 1 ? "s" : ""} today</p>}
            </div>

            <div style={{ marginBottom: 20 }}>
              <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 12 }}>FILTER BY CATEGORY</div>
              <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
                <button onClick={() => setSelectedCat(null)}
                  style={{ background: !selectedCat ? "#6366f133" : "#0f172a", border: `1px solid ${!selectedCat ? "#6366f1" : "#1e293b"}`, color: !selectedCat ? "#818cf8" : "#64748b", borderRadius: 8, padding: "6px 14px", fontSize: 12, fontWeight: !selectedCat ? 700 : 400, cursor: "pointer" }}>
                  All
                </button>
                {CATEGORIES.map(c => <CategoryPill key={c} cat={c} active={selectedCat === c} onClick={() => setSelectedCat(selectedCat === c ? null : c)} />)}
              </div>
            </div>

            <div style={{ marginBottom: 24 }}>
              <button onClick={() => fetchTopic(null, selectedCat)} disabled={loadingTopic}
                style={{ background: loadingTopic ? "#1e293b" : "linear-gradient(135deg,#6366f1,#8b5cf6)", color: loadingTopic ? "#475569" : "white", border: "none", borderRadius: 10, padding: "11px 22px", fontSize: 13, fontWeight: 700, cursor: loadingTopic ? "not-allowed" : "pointer" }}>
                {loadingTopic ? "⟳ Loading..." : `⚡ Generate${selectedCat ? ` ${selectedCat}` : ""} Topic`}
              </button>
            </div>

            <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 12 }}>
              {selectedCat ? `${selectedCat.toUpperCase()} TOPICS` : "SUGGESTED TOPICS — click any to load"}
            </div>
            <div style={{ display: "grid", gap: 8 }}>
              {(selectedCat ? SUGGESTED_TOPICS[selectedCat] : Object.values(SUGGESTED_TOPICS).flat().sort(() => Math.random() - 0.5).slice(0, 10)).map(t => (
                <button key={t} onClick={() => fetchTopic(t)}
                  style={{ background: "#0f172a", border: "1px solid #1e293b", borderRadius: 8, padding: "11px 14px", textAlign: "left", cursor: "pointer", color: "#94a3b8", fontSize: 13, transition: "all 0.2s" }}
                  onMouseEnter={e => { e.currentTarget.style.borderColor="#6366f1"; e.currentTarget.style.color="#f1f5f9"; }}
                  onMouseLeave={e => { e.currentTarget.style.borderColor="#1e293b"; e.currentTarget.style.color="#94a3b8"; }}>
                  {t}
                </button>
              ))}
            </div>

            {savedTopics.length > 0 && (
              <div style={{ marginTop: 28 }}>
                <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 12 }}>RECENTLY LEARNED</div>
                <div style={{ display: "grid", gap: 8 }}>
                  {savedTopics.slice(0, 5).map(t => <TopicCard key={t.topic} topic={t} onSelect={fetchTopic} />)}
                </div>
              </div>
            )}
          </div>
        )}

        {prepTab === "learn" && currentModule && <LearningModule module={currentModule} onBack={() => setCurrentModule(null)} />}

        {/* PRACTICE */}
        {prepTab === "practice" && !currentQ && (
          <div style={{ animation: "fadeIn 0.4s ease" }}>
            <div style={{ marginBottom: 24 }}>
              <h2 style={{ fontSize: 26, fontWeight: 700, fontFamily: "Georgia,serif", color: "#f1f5f9", letterSpacing: "-0.02em" }}>Practice Questions</h2>
              <p style={{ color: "#475569", fontSize: 13, marginTop: 4 }}>Senior-level questions from real ML/DE interviews. Type your answer and get instant Claude feedback.</p>
            </div>

            <div style={{ marginBottom: 20 }}>
              <div style={{ fontSize: 10, color: "#475569", fontWeight: 700, letterSpacing: "0.1em", marginBottom: 12 }}>CHOOSE CATEGORY</div>
              <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
                <button onClick={() => setSelectedCat(null)}
                  style={{ background: !selectedCat ? "#6366f133" : "#0f172a", border: `1px solid ${!selectedCat ? "#6366f1" : "#1e293b"}`, color: !selectedCat ? "#818cf8" : "#64748b", borderRadius: 8, padding: "6px 14px", fontSize: 12, fontWeight: !selectedCat ? 700 : 400, cursor: "pointer" }}>
                  🎲 Random
                </button>
                {CATEGORIES.map(c => <CategoryPill key={c} cat={c} active={selectedCat === c} onClick={() => setSelectedCat(selectedCat === c ? null : c)} />)}
              </div>
            </div>

            <button onClick={() => fetchQuestion(selectedCat)} disabled={loadingQ}
              style={{ background: loadingQ ? "#1e293b" : "linear-gradient(135deg,#6366f1,#8b5cf6)", color: loadingQ ? "#475569" : "white", border: "none", borderRadius: 10, padding: "11px 26px", fontSize: 14, fontWeight: 700, cursor: loadingQ ? "not-allowed" : "pointer", marginBottom: 28 }}>
              {loadingQ ? "⟳ Loading question..." : `🎯 Get${selectedCat ? ` ${selectedCat}` : " Random"} Question`}
            </button>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
              {CATEGORIES.map(cat => (
                <div key={cat} style={{ background: "#0f172a", border: `1px solid ${CAT_COLORS[cat]}22`, borderRadius: 12, padding: "16px 18px", cursor: "pointer", transition: "all 0.2s" }}
                  onClick={() => { setSelectedCat(cat); fetchQuestion(cat); }}
                  onMouseEnter={e => { e.currentTarget.style.borderColor = CAT_COLORS[cat]; e.currentTarget.style.transform = "translateY(-2px)"; }}
                  onMouseLeave={e => { e.currentTarget.style.borderColor = CAT_COLORS[cat] + "22"; e.currentTarget.style.transform = "none"; }}>
                  <div style={{ fontSize: 20, marginBottom: 8 }}>{CAT_ICONS[cat]}</div>
                  <div style={{ fontSize: 14, fontWeight: 700, color: "#f1f5f9", marginBottom: 4 }}>{cat}</div>
                  <div style={{ fontSize: 11, color: "#475569" }}>{SUGGESTED_TOPICS[cat]?.length} topics</div>
                  <div style={{ fontSize: 11, color: CAT_COLORS[cat], marginTop: 8, fontWeight: 600 }}>Practice →</div>
                </div>
              ))}
            </div>
          </div>
        )}

        {prepTab === "practice" && currentQ && <PracticeQuestion question={currentQ} onBack={() => setCurrentQ(null)} onNext={() => fetchQuestion(selectedCat)} />}

        {/* HISTORY */}
        {prepTab === "history" && (
          <div style={{ animation: "fadeIn 0.4s ease" }}>
            <div style={{ marginBottom: 24 }}>
              <h2 style={{ fontSize: 26, fontWeight: 700, fontFamily: "Georgia,serif", color: "#f1f5f9", letterSpacing: "-0.02em" }}>Prep History</h2>
              <p style={{ color: "#475569", fontSize: 13, marginTop: 4 }}>Track what you've studied</p>
            </div>

            <div style={{ display: "flex", gap: 10, marginBottom: 24, flexWrap: "wrap" }}>
              {CATEGORIES.map(c => {
                const count = history.filter(h => h.category === c).length;
                return (
                  <div key={c} style={{ background: "#0f172a", border: `1px solid ${CAT_COLORS[c]}33`, borderRadius: 10, padding: "10px 16px", textAlign: "center" }}>
                    <div style={{ fontSize: 20, fontWeight: 700, color: CAT_COLORS[c] }}>{count}</div>
                    <div style={{ fontSize: 9, color: "#475569", fontWeight: 600, marginTop: 2, letterSpacing: "0.05em" }}>{c.split(" ")[0].toUpperCase()}</div>
                  </div>
                );
              })}
            </div>

            {history.length === 0
              ? <div style={{ textAlign: "center", padding: "40px 0", color: "#334155" }}>No history yet — start learning or practicing!</div>
              : history.map((h, i) => (
                <div key={i} style={{ background: "#0f172a", border: `1px solid ${CAT_COLORS[h.category] || "#1e293b"}22`, borderRadius: 10, padding: "12px 16px", marginBottom: 8, display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                  <div>
                    <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 3 }}>
                      <span style={{ fontSize: 10, background: (CAT_COLORS[h.category] || "#475569") + "22", color: CAT_COLORS[h.category] || "#475569", borderRadius: 4, padding: "2px 7px", fontWeight: 700 }}>{h.type === "topic" ? "📖 LEARN" : "🎯 PRACTICE"}</span>
                      <span style={{ fontSize: 10, color: "#475569" }}>{h.category}</span>
                    </div>
                    <div style={{ color: "#94a3b8", fontSize: 13 }}>{h.topic}</div>
                  </div>
                  <div style={{ color: "#334155", fontSize: 11 }}>{new Date(h.date).toLocaleDateString()}</div>
                </div>
              ))
            }

            {history.length > 0 && (
              <button onClick={() => { setHistory([]); lsSave("prep-history", []); }}
                style={{ background: "transparent", border: "1px solid #334155", color: "#475569", borderRadius: 6, padding: "8px 16px", fontSize: 12, cursor: "pointer", marginTop: 10 }}>
                Clear history
              </button>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
